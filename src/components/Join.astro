---
import { Send, ExternalLink } from 'lucide-astro';
---

<section id="unirme" class="py-24 bg-base relative border-t-4 border-primary">
    <div class="container mx-auto px-6 md:px-12 text-center">
        
        <div class="max-w-3xl mx-auto reveal">
            <div class="w-16 h-16 bg-secondary rounded-full flex items-center justify-center text-primary mx-auto mb-6">
                <Send class="w-8 h-8" />
            </div>
            
            <h2 class="font-display text-4xl md:text-5xl text-primary mb-6">
                Formulario de Inscripción para Voluntarios
            </h2>
            
            <p class="text-gray-600 text-lg mb-10 leading-relaxed text-pretty">
                Si querés aplicar tus conocimientos técnicos en un entorno de impacto social, sumar experiencia valiosa y ayudar a derribar barreras digitales, te invitamos a sumarte a nuestra red.
            </p>
            
            <!-- Botón redirige a formulario externo -->
            <a href="https://munayruray.com/unete/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-accent text-primary font-bold text-xl py-5 px-10 rounded-xl shadow-lg hover:bg-yellow-400 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 w-full sm:w-auto group">
                Completar mi inscripción
                <ExternalLink class="ml-3 w-6 h-6 group-hover:rotate-12 transition-transform" />
            </a>
            
            <p class="mt-6 text-sm text-gray-400">
                Serás redirigido/a al formulario oficial de Munay Ruray.
            </p>
        </div>
    </div>
</section>
